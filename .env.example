# Discord bot token from https://discord.com/developers/applications -> isobot -> Bot -> Reset Token
DISCORD_BOT_TOKEN=

# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# GitHub fine-grained PAT with `Issues: read+write` on the repos in src/config/repos.json
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# Optional: override the OpenAI model used (defaults to gpt-5-mini-2025-08-07)
# OPENAI_MODEL=gpt-5-mini-2025-08-07

# Optional: comma-separated Discord user IDs allowed to trigger isobot.
# If unset, defaults to the application owner (whoever created the Discord app).
# ISOBOT_ALLOWED_USERS=123456789012345678,234567890123456789
